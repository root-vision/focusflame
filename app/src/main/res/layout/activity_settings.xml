<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1117">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingTop="48dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sozlamalar"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="24dp" />

        <!-- TELEGRAM CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#171A21"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📲 Telegram Yuborish"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="16dp" />

                <!-- Switch -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_centerVertical="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bildirishnomalarni yuborish"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Barcha bildirishnomalar Telegramga ketadi"
                            android:textColor="#9AA4B2"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <Switch
                        android:id="@+id/switchForwarding"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:thumbTint="#6C5CFF"
                        android:trackTint="#2A2D38"
                        android:checked="true" />
                </RelativeLayout>

                <!-- Bot status -->
                <TextView
                    android:id="@+id/tvBotStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📡 Tekshirilmoqda..."
                    android:textColor="#9AA4B2"
                    android:textSize="13sp"
                    android:background="#0F1117"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp" />

                <!-- Test tugmasi -->
                <TextView
                    android:id="@+id/btnTestBot"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/btn_outline"
                    android:gravity="center"
                    android:text="🤖 Telegram Botni Test Qilish"
                    android:textColor="#6C5CFF"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="8dp" />

                <!-- Notification Access -->
                <TextView
                    android:id="@+id/btnNotifAccess"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/btn_outline"
                    android:gravity="center"
                    android:text="🔔 Notification Ruxsatini Berish"
                    android:textColor="#FF7A00"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- TAYMER CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#171A21"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱️ Taymer Sozlamalari"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="20dp" />

                <!-- Focus duration -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Focus muddati"
                    android:textColor="#9AA4B2"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp">

                    <SeekBar
                        android:id="@+id/seekFocus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toStartOf="@+id/tvFocusVal"
                        android:layout_centerVertical="true"
                        android:max="60"
                        android:progress="25"
                        android:progressTint="#6C5CFF"
                        android:thumbTint="#6C5CFF"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:id="@+id/tvFocusVal"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="25 daqiqa"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:gravity="end" />
                </RelativeLayout>

                <!-- Break duration -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dam olish muddati"
                    android:textColor="#9AA4B2"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <SeekBar
                        android:id="@+id/seekBreak"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toStartOf="@+id/tvBreakVal"
                        android:layout_centerVertical="true"
                        android:max="30"
                        android:progress="5"
                        android:progressTint="#6C5CFF"
                        android:thumbTint="#6C5CFF"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:id="@+id/tvBreakVal"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="5 daqiqa"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:gravity="end" />
                </RelativeLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- INFO CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#171A21"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ℹ️ Qanday ishlaydi"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• Barcha bildirishnomalar Telegramga yuboriladi\n• Telegram xabarlari yuborilmaydi (loop yo'q)\n• Ilova YOPIQ bo'lsa ham ishlaydi\n• Telefon o'chib yonsa ham qayta ishlaydi\n• @FtestChat_bot orqali qabul qilinadi"
                    android:textColor="#9AA4B2"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.6" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Focus Flame v1.0"
                    android:textColor="#2A2D38"
                    android:textSize="12sp"
                    android:layout_marginTop="16dp"
                    android:layout_gravity="center_horizontal" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
